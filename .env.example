# ============================================================
#  Sanctum Backend — environment template (PLACEHOLDERS ONLY)
#  Copy to .env and fill with real values. NEVER commit .env.
# ============================================================

# ---- Runtime / server ----
NODE_ENV=development
PORT=8080

# ---- CORS / frontend linkage ----
FRONTEND_ORIGIN=http://localhost:3000

# ---- Table prefixing (collision-safety on a shared Turso DB) ----
# Default is "sanctum_". Set to "" for a dedicated DB with bare names.
TABLE_PREFIX=sanctum_

# ---- Database (Turso / libSQL) ----
TURSO_DATABASE_URL=libsql://your-db-your-org.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# ---- Auth / JWT (32+ random bytes each, distinct keys) ----
JWT_ACCESS_SECRET=replace-with-a-long-random-secret-min-32-chars
JWT_REFRESH_SECRET=replace-with-a-different-long-random-secret-min-32

# ---- Credentials vault encryption (AES-256-GCM) ----
# 32-byte key, base64-encoded. Generate: openssl rand -base64 32
VAULT_ENC_KEY=replace-with-base64-of-32-random-bytes

# ---- Cloudinary (signed uploads) ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# ---- Google Gemini (AI content generation) — primary provider ----
# If GEMINI_API_KEY is omitted, AI generation falls back to a deterministic
# local template generator (it never returns 501 / never fails the request).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest

# Preferred provider. 'gemini' is the only live provider; any other value
# forces the deterministic fallback.
AI_PROVIDER=gemini

# ---- Anthropic (Claude) — OPTIONAL, legacy / back-compat only ----
# No longer used for generation. Retained so older .env files keep validating.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5
